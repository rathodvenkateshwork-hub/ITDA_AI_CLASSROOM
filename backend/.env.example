# Supabase (for API server)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Optional: API server port (default 3001)
# PORT=3001

# Note:
# Frontend env is now in frontend/.env and frontend/.env.example
# Set VITE_API_URL there to point to this backend URL.
